{
  "manifest_version": 3,
  "name": "CareerForge AI — Job Tracker",
  "version": "1.0.0",
  "description": "One-click job tracking from LinkedIn, Indeed, and Glassdoor to CareerForge AI",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://bd.indeed.com/*",
    "https://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://www.indeed.com/jobs*",
        "https://bd.indeed.com/viewjob*",
        "https://www.glassdoor.com/job-listing/*",
        "https://www.glassdoor.com/Jobs/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}